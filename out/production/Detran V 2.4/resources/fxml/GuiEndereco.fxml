<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="670.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <left>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <GridPane hgap="8.0" vgap="8.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Endereco" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="jtEndereco" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Label text="Logradouro" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextField fx:id="jtLogradouro" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Numero" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <TextField fx:id="jtNumero" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label text="Complemento" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                  <TextField fx:id="jtComplemento" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label text="Bairro" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <TextField fx:id="jtBairro" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <Label text="Estado" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                  <ComboBox fx:id="jcbEstado" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  <Label text="Cidade" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                  <ComboBox fx:id="jcbCidade" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                  <Label text="CEP" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                  <TextField fx:id="jtCep" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                  <Label text="Condutor" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                  <ComboBox fx:id="jcbCondutor" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="8" />
               </children>
            </GridPane>
            <HBox spacing="8.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#cadastrar" text="Cadastrar" />
                  <Button mnemonicParsing="false" onAction="#atualizarTabela" text="Visualizar" />
                  <Button mnemonicParsing="false" onAction="#handleLimpar" text="Limpar" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <TableView fx:id="jTableEndereco" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="c1" prefWidth="80.0" text="Codigo" />
          <TableColumn fx:id="c2" prefWidth="120.0" text="Endereco" />
            <TableColumn fx:id="c3" prefWidth="120.0" text="Logradouro" />
            <TableColumn fx:id="c4" prefWidth="80.0" text="Numero" />
            <TableColumn fx:id="c5" prefWidth="120.0" text="Complemento" />
            <TableColumn fx:id="c6" prefWidth="120.0" text="Bairro" />
            <TableColumn fx:id="c7" prefWidth="80.0" text="Estado" />
            <TableColumn fx:id="c8" prefWidth="120.0" text="Cidade" />
            <TableColumn fx:id="c9" prefWidth="100.0" text="CEP" />
            <TableColumn fx:id="c10" prefWidth="120.0" text="Condutor" />
        </columns>
      </TableView>
   </center>
</BorderPane>

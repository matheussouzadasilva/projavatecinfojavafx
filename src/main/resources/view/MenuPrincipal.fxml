<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="670.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <MenuBar>
              <menus>
                <Menu mnemonicParsing="false" text="Cadastrar">
                  <items>
                    <MenuItem fx:id="jmiUsuario" mnemonicParsing="false" onAction="#handleCadastrarUsuario" text="Usuario" />
                    <MenuItem mnemonicParsing="false" onAction="#handleCadastrarMulta" text="Multa" />
                    <MenuItem mnemonicParsing="false" onAction="#handleCadastrarAutomovel" text="Automovel" />
                    <MenuItem mnemonicParsing="false" onAction="#handleCadastrarCondutor" text="Condutor" />
                    <MenuItem mnemonicParsing="false" onAction="#handleCadastrarEndereco" text="Endereco" />
                  </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Deletar">
                  <items>
                    <MenuItem mnemonicParsing="false" onAction="#handleDeletarCondutor" text="Condutor" />
                    <MenuItem mnemonicParsing="false" onAction="#handleDeletarEndereco" text="Endereco" />
                  </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Manutenção">
                  <items>
                    <MenuItem mnemonicParsing="false" onAction="#handleManutencaoMulta" text="Multa" />
                    <MenuItem mnemonicParsing="false" onAction="#handleManutencaoAutomovel" text="Automovel" />
                  </items>
                </Menu>
                <Menu mnemonicParsing="false" text="Login">
                  <items>
                    <MenuItem mnemonicParsing="false" onAction="#handleLogarOutro" text="Logar Com Outro Usuario" />
                    <MenuItem mnemonicParsing="false" onAction="#handleSair" text="Sair" />
                  </items>
                </Menu>
              </menus>
            </MenuBar>
         </children>
      </VBox>
   </top>
</BorderPane>

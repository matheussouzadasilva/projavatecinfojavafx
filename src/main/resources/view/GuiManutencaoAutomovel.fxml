<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="670.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <left>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <GridPane hgap="8.0" vgap="8.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Codigo" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="jtCodigo" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Label text="Marca" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextField fx:id="jtMarca" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="Modelo" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <TextField fx:id="jtModelo" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label text="Ano" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                  <TextField fx:id="jtAno" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label text="Placa" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <TextField fx:id="jtPlaca" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <Label text="Multa" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                  <ComboBox fx:id="jcbMulta" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
               </children>
            </GridPane>
            <HBox spacing="8.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#inserirTodosAutomoveisNaTabela" text="Visualizar" />
                  <Button mnemonicParsing="false" onAction="#carregarSelecionado" text="Alterar" />
                  <Button mnemonicParsing="false" onAction="#salvarAlteracoes" text="Salvar Alteracoes" />
                  <Button mnemonicParsing="false" onAction="#deletarSelecionado" text="Deletar" />
                  <Button mnemonicParsing="false" onAction="#handleLimpar" text="Limpar" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <TableView fx:id="jTableAutomovel" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="c1" prefWidth="80.0" text="Codigo" />
          <TableColumn fx:id="c2" prefWidth="120.0" text="Marca" />
            <TableColumn fx:id="c3" prefWidth="120.0" text="Modelo" />
            <TableColumn fx:id="c4" prefWidth="80.0" text="Ano" />
            <TableColumn fx:id="c5" prefWidth="100.0" text="Placa" />
            <TableColumn fx:id="c6" prefWidth="150.0" text="Multa" />
        </columns>
      </TableView>
   </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane prefHeight="670.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <left>
      <VBox spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <GridPane hgap="8.0" vgap="8.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Nome" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="jtNome" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Label text="Sobrenome" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextField fx:id="jtSobrenome" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label text="RG" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <TextField fx:id="jtRg" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Label text="CPF" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                  <TextField fx:id="jtCpf" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label text="Data de Nascimento" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <TextField fx:id="jtDatanascimento" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <Label text="CNH" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                  <TextField fx:id="jtCnh" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  <Label text="Automovel" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                  <ComboBox fx:id="jcbMulta" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                  <Label text="Sexo" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                  <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="7">
                     <children>
                        <RadioButton fx:id="jrbMasculino" mnemonicParsing="false" text="Masculino">
                           <toggleGroup>
                              <ToggleGroup fx:id="bgSexo" />
                           </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="jrbFeminino" mnemonicParsing="false" text="Feminino" toggleGroup="$bgSexo" />
                     </children>
                  </HBox>
               </children>
            </GridPane>
            <HBox spacing="8.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#cadastrar" text="Cadastrar" />
                  <Button mnemonicParsing="false" onAction="#atualizarTabela" text="Visualizar" />
                  <Button mnemonicParsing="false" onAction="#handleLimpar" text="Limpar" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <TableView fx:id="jTableCondutor" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="c1" prefWidth="80.0" text="Codigo" />
          <TableColumn fx:id="c2" prefWidth="80.0" text="Sexo" />
            <TableColumn fx:id="c3" prefWidth="120.0" text="Nome" />
            <TableColumn fx:id="c4" prefWidth="120.0" text="Sobrenome" />
            <TableColumn fx:id="c5" prefWidth="100.0" text="RG" />
            <TableColumn fx:id="c6" prefWidth="100.0" text="CPF" />
            <TableColumn fx:id="c7" prefWidth="100.0" text="Nascimento" />
            <TableColumn fx:id="c8" prefWidth="100.0" text="CNH" />
            <TableColumn fx:id="c9" prefWidth="100.0" text="Placa" />
        </columns>
      </TableView>
   </center>
</BorderPane>
